{
	"name": "obsidian-auto-plus",
	"version": "2.1.0",
	"description": "增强版自动笔记处理器，支持 YAML 属性判断、多种操作类型和灵活的规则配置。适配 Obsidian 2026 API。",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint . --ext .ts || true",
		"typecheck": "tsc -noEmit --strict",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"auto-move",
		"auto-rename",
		"yaml",
		"automation",
		"fuzzy-search"
	],
	"author": "SantaChains",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.13.0",
		"@typescript-eslint/eslint-plugin": "^8.22.0",
		"@typescript-eslint/parser": "^8.22.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.24.0",
		"obsidian": "^1.7.2",
		"tslib": "^2.8.1",
		"typescript": "^5.7.3"
	},
	"dependencies": {
		"ajv": "^8.18.0",
		"ajv-formats": "^3.0.1"
	}
}
