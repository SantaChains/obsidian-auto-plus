{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2020",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "isolatedModules": true,
    "strict": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "strictBindCallApply": false,
    "strictPropertyInitialization": false,
    "noImplicitThis": false,
    "alwaysStrict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "lib": [
      "DOM",
      "ES2020"
    ]
  },
  "include": [
    "main.v3.ts",
    "v3/core/**/*.ts",
    "v3/components/canvas/**/*.ts",
    "v3/components/config/**/*.ts",
    "v3/persistence/**/*.ts",
    "v3/views/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "v3/interactions/**/*.ts"
  ]
}
